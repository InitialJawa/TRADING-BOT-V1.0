# === WAJIB ===
OPENCODE_API_KEY=sk-...        # API key untuk OpenCode/OpenAI provider

# === OPSIONAL ===
OPCODE_CMD=                    # Path ke opencode CLI (default: from PATH)
OPENCODE_BASE_URL=             # Base URL API (default: opencode.ai/zen/v1)
OPENCODE_MODEL=                # Model name (default: minimax-m2.5-free)
GEMINI_API_KEY=                # API key untuk Gemini fallback
MT5_PATH=                      # Path ke terminal64.exe MT5
MT5_DATA_PATH=                 # Path ke data folder MT5
